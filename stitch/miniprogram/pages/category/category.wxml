<view class="page">
  <view class="nav-bar">
    <view class="nav-search" bindtap="onSearch">
      <view class="css-search"></view>
      <text class="sp">搜索全部商品</text>
    </view>
    <image class="av" src="{{userInfo?userInfo.avatarUrl:''}}" mode="aspectFill" bindtap="goProfile"></image>
  </view>

  <view class="body">
    <scroll-view scroll-y class="sidebar" enhanced show-scrollbar="{{false}}">
      <block wx:for="{{clist}}" wx:key="id">
        <view class="sitem" hover-class="sipress" data-id="{{item.id}}" bindtap="onCatChange">
          <view class="slabel {{curC===item.id?'active':''}}">{{item.name}}</view>
        </view>
      </block>
    </scroll-view>

    <scroll-view scroll-y class="p-area" enhanced show-scrollbar="{{false}}">
      <view class="phdr anim-fade-in">
        <text class="ptitle">{{curName}}</text>
        <text class="psub">为您精选的高品质好物</text>
      </view>

      <view class="plist anim-fade-in" style="animation-delay:0.1s;">
        <block wx:for="{{prods}}" wx:key="id">
          <view class="pcard" hover-class="ppress" bindtap="toDetail" data-id="{{item.id}}">
            <view class="pimg-wrap">
              <image class="pimg" src="{{item.image}}" mode="aspectFill" lazy-load binderror="onImgErr" data-index="{{index}}"></image>
              <view class="pimg-fallback {{item._loaded ? 'hidden' : ''}}">
                <text class="pf-text">{{item.name[0]}}</text>
              </view>
            </view>
            <view class="pcontent">
              <view class="ptop">
                <text class="pname text-line2">{{item.name}}</text>
              </view>
              
              <view class="p-mid">
                <text class="ptag {{item.tagColor==='primary'?'tp':item.tagColor==='secondary'?'ts':'tt'}}">{{item.tag}}</text>
                <text class="pweight">{{item.weight}}</text>
              </view>

              <view class="pbtm">
                <view class="pprice-box">
                  <text class="pprice">{{item.priceText}}</text>
                </view>
                <view class="abtn" catchtap="addCart" data-id="{{item.id}}">
                  <view class="css-plus-small"></view>
                </view>
              </view>
            </view>
          </view>
        </block>

        <view wx:if="{{empty}}" class="empty anim-fade-in">
          <view class="css-box"></view>
          <text class="et">暂无该分类商品</text>
          <text class="es">请查看其他分类</text>
        </view>
      </view>

      <view style="height:100rpx"></view>
    </scroll-view>
  </view>
</view>