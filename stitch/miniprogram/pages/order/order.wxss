.opage{height:100vh;background:var(--clr-bg);padding:24rpx;padding-bottom:0;box-sizing:border-box;}
.card{background:var(--clr-card);border-radius:24rpx;padding:32rpx;margin-bottom:24rpx;box-shadow:var(--shadow-sm);}
.addr-card{padding:36rpx 32rpx;position:relative;}
.addr-card::before{
  content:'';position:absolute;bottom:0;left:0;right:0;height:6rpx;
  background:repeating-linear-gradient(-45deg, var(--clr-primary) 0, var(--clr-primary) 20rpx, transparent 20rpx, transparent 40rpx, var(--clr-primary-light) 40rpx, var(--clr-primary-light) 60rpx, transparent 60rpx, transparent 80rpx);
}
.ah{display:flex;align-items:center;gap:16rpx;margin-bottom:12rpx;}
.an{font-size:32rpx;font-weight:900;color:var(--clr-text);}
.ap{font-size:26rpx;color:var(--clr-text-secondary);font-weight:600;}
.at{font-size:20rpx;background:var(--clr-primary-bg);color:var(--clr-primary);padding:4rpx 14rpx;border-radius:6rpx;font-weight:800;}
.ad{font-size:26rpx;color:var(--clr-text-secondary);line-height:1.6;display:block;}
.css-arrow-right{
  position:absolute;right:32rpx;top:50%;transform:translateY(-50%) rotate(45deg);
  width:16rpx;height:16rpx;border-top:4rpx solid var(--clr-text-muted);border-right:4rpx solid var(--clr-text-muted);
}
.addr-empty{display:flex;align-items:center;gap:16rpx;padding:20rpx 0;}
.css-pin-dark{
  width:24rpx;height:24rpx;border:4rpx solid var(--clr-text);
  border-radius:50% 50% 50% 0;transform:rotate(-45deg);
}
.aet{font-size:30rpx;color:var(--clr-text);font-weight:800;flex:1;}
.aa{font-size:36rpx;color:var(--clr-text-muted);font-weight:bold;}

.cl-top{margin-bottom:24rpx;}
.cl{font-size:30rpx;font-weight:900;color:var(--clr-text);display:block;margin-bottom:24rpx;}
.gi{display:flex;gap:24rpx;padding:24rpx 0;border-bottom:1rpx solid var(--clr-border);}
.gi:last-child{border-bottom:none;padding-bottom:0;}
.gimg{width:140rpx;height:140rpx;border-radius:18rpx;background:#f0f2ec;}
.gn{flex:1;display:flex;flex-direction:column;justify-content:center;gap:8rpx;}
.gnname{font-size:28rpx;color:var(--clr-text);font-weight:800;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;}
.gns{font-size:24rpx;color:var(--clr-text-muted);font-weight:500;}
.gb{display:flex;justify-content:space-between;align-items:center;margin-top:auto;}
.gpr{font-size:32rpx;font-weight:900;color:var(--clr-text);}
.gqty{font-size:26rpx;color:var(--clr-text-secondary);font-weight:600;}

.opt{display:flex;align-items:center;padding:24rpx 0;}
.border-btm{border-bottom:1rpx solid var(--clr-border);}
.opt.active .ock{color:var(--clr-primary);font-weight:900;}

.css-truck-opt{
  width:40rpx;height:30rpx;border:4rpx solid var(--clr-text);
  border-radius:4rpx 12rpx 4rpx 4rpx;margin-right:24rpx;position:relative;
}
.css-truck-opt::after{
  content:'';position:absolute;bottom:-8rpx;left:4rpx;width:10rpx;height:10rpx;
  background:var(--clr-text);border-radius:50%;box-shadow:18rpx 0 0 var(--clr-text);
}
.css-wechat{
  width:40rpx;height:36rpx;border:4rpx solid #10b981;border-radius:50%;
  margin-right:24rpx;position:relative;
}
.css-wechat::after, .css-wechat::before{
  content:'';position:absolute;background:#10b981;border-radius:50%;
}
.css-wechat::before{width:8rpx;height:8rpx;top:8rpx;left:8rpx;box-shadow:12rpx 0 0 #10b981;}

.oot{flex:1;}
.ootitle{font-size:28rpx;color:var(--clr-text);font-weight:800;display:block;}
.oodesc{font-size:22rpx;color:var(--clr-text-muted);margin-top:6rpx;display:block;font-weight:500;}
.ock{font-size:32rpx;color:var(--clr-text-muted);}

.remark-card{padding:24rpx 32rpx;}
.ri{font-size:28rpx;color:var(--clr-text);font-weight:500;width:100%;}

.price-card{padding-bottom:24rpx;}
.pr{display:flex;justify-content:space-between;padding:16rpx 0;font-size:26rpx;}
.pl{color:var(--clr-text-secondary);font-weight:500;}
.pv{color:var(--clr-text);font-weight:800;}
.pv.free{color:var(--clr-primary);}
.pv.disc{color:var(--clr-danger);}
.divider{height:1rpx;background:var(--clr-border);margin:16rpx 0;}
.pr.total{margin-top:0;padding-top:24rpx;align-items:flex-end;}
.plt{font-size:30rpx;color:var(--clr-text);font-weight:800;margin-bottom:6rpx;}
.pvt{font-size:44rpx;font-weight:900;color:var(--clr-danger);}

.submit-bar{
  position:fixed;bottom:0;left:0;right:0;z-index:99;background:var(--clr-card);
  display:flex;justify-content:space-between;align-items:center;
  padding:20rpx 32rpx;padding-bottom:calc(20rpx + env(safe-area-inset-bottom));
  box-shadow:0 -8rpx 32rpx rgba(0,0,0,0.06);
}
.si{display:flex;align-items:baseline;gap:8rpx;}
.sl{font-size:28rpx;color:var(--clr-text-secondary);font-weight:600;}
.st{font-size:42rpx;font-weight:900;color:var(--clr-danger);}
.sb{
  background:var(--clr-primary);color:var(--clr-card);
  font-size:30rpx;font-weight:900;padding:24rpx 56rpx;
  border-radius:var(--radius-pill);border:none;margin:0;line-height:1;
  box-shadow:0 8rpx 20rpx rgba(58,107,0,0.25);
}
.sb-press{transform:scale(0.96);}