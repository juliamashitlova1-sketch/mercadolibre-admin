page { background: var(--clr-bg); }

/* 导航 */
.nav-bar{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;justify-content:space-between;align-items:center;
  padding:24rpx 32rpx;padding-top:calc(20rpx + env(safe-area-inset-top));
  background:rgba(255, 255, 255, 0.95);
  backdrop-filter:blur(16rpx); -webkit-backdrop-filter:blur(16rpx);
  border-bottom:1rpx solid var(--clr-border);
}
.nav-search{
  flex:1;height:72rpx;background:var(--clr-bg);border-radius:var(--radius-pill);
  display:flex;align-items:center;padding:0 32rpx;margin-right:24rpx;
}
.css-search{
  width:22rpx;height:22rpx;border:3rpx solid #afb4a5;border-radius:50%;
  position:relative;margin-right:16rpx;
}
.css-search::after{
  content:'';position:absolute;bottom:-6rpx;right:-8rpx;
  width:8rpx;height:3rpx;background:#afb4a5;transform:rotate(45deg);
}
.sp{font-size:26rpx;color:#afb4a5;font-weight:500;}

.av{
  width:72rpx;height:72rpx;border-radius:50%;
  background:#ecece5;border:4rpx solid #fff;box-shadow:var(--shadow-sm);
  flex-shrink:0;
}

/* 布局 */
.body{display:flex;margin-top:calc(110rpx + env(safe-area-inset-top));height:calc(100vh - 110rpx - env(safe-area-inset-top));}

/* 侧边栏 */
.sidebar{width:180rpx;height:100%;flex-shrink:0;}
.sitem{
  padding:24rpx 16rpx;display:flex;justify-content:center;
}
.slabel{
  font-size:26rpx;color:var(--clr-text-secondary);font-weight:500;
  padding:12rpx 20rpx;border-radius:16rpx;transition:all 0.1s ease;
  width:100%;text-align:center;
}
.slabel.active{
  background:var(--clr-card);color:var(--clr-primary);font-weight:800;
  box-shadow:var(--shadow-sm);position:relative;
}
.slabel.active::before{
  content:'';position:absolute;left:-8rpx;top:50%;transform:translateY(-50%);
  width:10rpx;height:32rpx;background:var(--clr-primary);border-radius:8rpx;
}
.sipress{opacity:0.7;}

/* 右侧内容 */
.p-area{flex:1;height:100%;padding:16rpx 24rpx 24rpx 24rpx;}
.phdr{margin-bottom:32rpx;margin-top:12rpx;}
.ptitle{font-size:40rpx;font-weight:900;color:var(--clr-text);display:block;}
.psub{font-size:24rpx;color:var(--clr-text-muted);display:block;margin-top:8rpx;}

/* 列表 */
.plist{display:flex;flex-direction:column;gap:32rpx;}
.pcard{
  background:var(--clr-card);border-radius:var(--radius-lg);
  display:flex;gap:24rpx;padding:24rpx;box-shadow:var(--shadow-sm);
}
.ppress{background:#fcfdfa;transform:scale(0.99);}
.pimg-wrap{
  width:180rpx;height:180rpx;border-radius:var(--radius-md);
  overflow:hidden;flex-shrink:0;background:#efefe8;position:relative;
}
.pimg{width:100%;height:100%;transition:opacity 0.3s;}
.pimg-fallback{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--clr-primary-light),#7dd327);
  transition:opacity 0.3s;
}
.pimg-fallback.hidden{opacity:0;pointer-events:none;}
.pf-text{font-size:56rpx;font-weight:900;color:white;opacity:0.9;}

.pcontent{flex:1;display:flex;flex-direction:column;justify-content:space-between;}
.ptop{margin-bottom:8rpx;}
.pname{font-size:28rpx;font-weight:800;color:var(--clr-text);line-height:1.4;}

.p-mid{display:flex;align-items:center;gap:12rpx;margin-bottom:12rpx;}
.pweight{font-size:22rpx;color:var(--clr-text-muted);}

.ptag{
  font-size:18rpx;font-weight:800;padding:2rpx 10rpx;
  border-radius:6rpx;display:inline-block;
}
.tp{color:var(--clr-primary);border:2rpx solid var(--clr-primary);background:transparent;}
.ts{color:#c62828;background:#ffcdd2;}
.tt{color:#f57f17;background:#fff9c4;}

.pbtm{display:flex;justify-content:space-between;align-items:flex-end;}
.pprice{font-size:36rpx;font-weight:900;color:var(--clr-text);}

/* 加购按钮 */
.abtn{
  width:60rpx;height:60rpx;border-radius:50%;
  background:var(--clr-primary);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4rpx 12rpx rgba(58,107,0,0.3);
}
.css-plus-small{width:20rpx;height:20rpx;position:relative;}
.css-plus-small::before, .css-plus-small::after{
  content:'';position:absolute;background:white;border-radius:2rpx;
}
.css-plus-small::before{top:8rpx;left:0;right:0;height:4rpx;}
.css-plus-small::after{bottom:0;top:0;left:8rpx;width:4rpx;}

/* 空状态 */
.empty{display:flex;flex-direction:column;align-items:center;padding:120rpx 0;opacity:0.6;}
.css-box{
  width:80rpx;height:80rpx;border:4rpx solid var(--clr-text-muted);
  border-radius:12rpx;position:relative;margin-bottom:32rpx;
}
.css-box::after{
  content:'';position:absolute;top:30rpx;left:0;right:0;
  border-top:4rpx dotted var(--clr-text-muted);
}
.et{font-size:28rpx;font-weight:700;color:var(--clr-text-muted);}
.es{font-size:24rpx;color:var(--clr-border);margin-top:8rpx;}