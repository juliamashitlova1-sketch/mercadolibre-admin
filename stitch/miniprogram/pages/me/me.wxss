.page { display: flex; flex-direction: column; height: 100vh; background: var(--clr-bg); }

/* 头部 */
.hdr {
  padding: 40rpx 40rpx 40rpx; padding-top:calc(20rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, var(--clr-primary), #244300);
  border-radius: 0 0 56rpx 56rpx;
  position: relative; padding-bottom: 90rpx;
  box-shadow:0 12rpx 32rpx rgba(58,107,0,0.25);
}
.htop { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.htitle { font-size: 48rpx; font-weight: 900; color: #fff; letter-spacing: 2rpx; }
.hicons { display: flex; gap: 24rpx; }
.icon-btn{width:64rpx;height:64rpx;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;}

/* CSS Top Icons */
.css-settings{width:24rpx;height:24rpx;border:4rpx solid #fff;border-radius:50%;position:relative;}
.css-settings::before, .css-settings::after{content:'';position:absolute;background:#fff;border-radius:2rpx;}
.css-settings::before{top:-6rpx;bottom:-6rpx;left:8rpx;width:8rpx;z-index:-1;}
.css-settings::after{left:-6rpx;right:-6rpx;top:8rpx;height:8rpx;z-index:-1;}
.css-bell{width:24rpx;height:20rpx;border:4rpx solid #fff;border-bottom:none;border-radius:12rpx 12rpx 0 0;position:relative;}
.css-bell::after{content:'';position:absolute;bottom:-10rpx;left:-4rpx;right:-4rpx;border-bottom:4rpx solid #fff;}

/* 用户卡片 */
.ucard {
  background: var(--clr-card); border-radius: 32rpx;
  padding: 32rpx; display: flex; align-items: center; gap: 24rpx;
  box-shadow: var(--shadow-lg); position: absolute;
  bottom: -56rpx; left: 32rpx; right: 32rpx; z-index:10;
}
.uav-btn {
  width: 112rpx; height: 112rpx; border-radius: 50%;
  background: var(--clr-bg); display: flex; align-items: center; justify-content: center;
  padding: 0; margin: 0; flex-shrink: 0; border:4rpx solid #fff; box-shadow:var(--shadow-sm);
}
.uav { width: 100%; height: 100%; border-radius: 50%; }
.css-user-large{
  width:32rpx;height:12rpx;border:4rpx solid var(--clr-text-muted);border-bottom:none;
  border-radius:16rpx 16rpx 0 0;position:absolute;bottom:24rpx;
}
.css-user-large::before{
  content:'';position:absolute;top:-28rpx;left:50%;transform:translateX(-50%);
  width:20rpx;height:20rpx;border:4rpx solid var(--clr-text-muted);border-radius:50%;
}
.uinfo { flex: 1; }
.uw { font-size: 34rpx; color: var(--clr-text); font-weight: 900; display: block; margin-bottom: 8rpx; }
.ua-wrap{display:inline-block;background:var(--clr-primary-bg);padding:4rpx 12rpx;border-radius:8rpx;}
.ua { font-size: 20rpx; color: var(--clr-primary);font-weight:800; }
.nick-input { font-size: 24rpx; color: var(--clr-text); margin-top: 10rpx; padding: 6rpx 0; border-bottom: 2rpx solid var(--clr-border); }
.lbtn {
  font-size: 24rpx; padding: 16rpx 36rpx; border-radius: var(--radius-pill);
  background: var(--clr-primary); color: #fff; font-weight: 800;
  line-height: 1; flex-shrink: 0; margin:0; box-shadow:0 6rpx 16rpx rgba(58,107,0,0.25);
}
.lout { background: #f3f5e9; color: var(--clr-text-secondary); box-shadow:none; }

/* 主区域 */
.main { flex: 1; padding: 0 32rpx; margin-top: 76rpx; }
.sec { margin-top: 40rpx; }
.st { font-size: 34rpx; font-weight: 900; color: var(--clr-text); margin-bottom: 24rpx; display: block; }
.st.blk { background: none; }
.osec { background: var(--clr-card); border-radius: var(--radius-lg); padding: 32rpx; box-shadow:var(--shadow-sm); }
.shdr { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 28rpx; }
.sm { font-size: 25rpx; color: var(--clr-text-muted); font-weight:600; }

.ogrid { display: flex; justify-content:space-between; padding:0 10rpx; }
.oitem { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.oipress { opacity: 0.7; transform:scale(0.96); transition:transform 0.1s; }
.ol { font-size: 24rpx; color: var(--clr-text-secondary); font-weight: 600; }

/* 宫格项 CSS 图标 */
.css-wallet{
  width:44rpx;height:32rpx;border:3rpx solid var(--clr-primary);border-radius:6rpx;
  position:relative;margin:10rpx 0;
}
.css-wallet::after{
  content:'';position:absolute;top:50%;right:-4rpx;transform:translateY(-50%);
  width:6rpx;height:12rpx;background:var(--clr-primary);border-radius:4rpx;
}
.css-truck-line{
  width:36rpx;height:24rpx;border:3rpx solid var(--clr-primary);border-radius:4rpx 8rpx 0 0;
  border-bottom:none;position:relative;margin:14rpx 0;
}
.css-truck-line::after{
  content:'';position:absolute;bottom:-4rpx;left:6rpx;box-shadow:18rpx 0 0 var(--clr-primary);
  width:8rpx;height:8rpx;border-radius:50%;background:var(--clr-primary);
}
.css-check-circle{
  width:36rpx;height:36rpx;border:3rpx solid var(--clr-primary);border-radius:50%;
  position:relative;margin:8rpx 0;
}
.css-check-circle::after{
  content:'';position:absolute;top:10rpx;left:10rpx;width:12rpx;height:6rpx;
  border-left:3rpx solid var(--clr-primary);border-bottom:3rpx solid var(--clr-primary);transform:rotate(-45deg);
}
.css-shield{
  width:36rpx;height:40rpx;border:3rpx solid var(--clr-primary);
  border-radius:6rpx 6rpx 20rpx 20rpx;position:relative;margin:6rpx 0;
}
.css-shield::after{
  content:'';position:absolute;top:10rpx;left:50%;transform:translateX(-50%);
  width:8rpx;height:8rpx;border-radius:50%;background:var(--clr-primary);
}

.bento { display: flex; gap: 24rpx; margin-bottom: 32rpx; }
.bcard {
  flex: 1; background: var(--clr-card); border-radius: var(--radius-lg);
  padding: 32rpx 24rpx; display: flex; flex-direction: column; align-items: flex-start;
  box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
}
.bc-press { background:#fcfdfa; transform: scale(0.98); transition:all 0.1s;}
.bg-pink{background:#fdf2f8;}
.bg-yellow{background:#fffbeb;}
.bi {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom:16rpx;
}
.css-pin-w{width:16rpx;height:16rpx;border:4rpx solid #ec4899;border-radius:50% 50% 50% 0;transform:rotate(-45deg);}
.css-star-w{
  width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-bottom: 20rpx solid #f59e0b;
  position:relative; top:-2rpx;
}
.css-star-w::after{
  content:'';position:absolute;top:20rpx;left:-10rpx;border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-top: 20rpx solid #f59e0b;
}

.bn { font-size: 28rpx; color: var(--clr-text); font-weight: 800; }
.bp { font-size: 32rpx; color: #d97706; font-weight: 900; margin-top: 6rpx; }
.bp-sm{font-size:22rpx;font-weight:700;}

.slist { background: var(--clr-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow:var(--shadow-sm); }
.slrow { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid var(--clr-border); }
.sli-css { width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;margin-right:20rpx;background:var(--clr-bg);border-radius:12rpx;}

/* 小列表图标 */
.css-paper{width:20rpx;height:24rpx;border:3rpx solid var(--clr-text);border-radius:4rpx;}
.css-headset{width:24rpx;height:24rpx;border:3rpx solid var(--clr-text);border-bottom:none;border-radius:16rpx 16rpx 0 0;}
.css-gift{width:20rpx;height:16rpx;border:3rpx solid var(--clr-text);position:relative;margin-top:4rpx;}
.css-gift::before{content:'';position:absolute;top:-10rpx;left:50%;transform:translateX(-50%);width:6rpx;height:6rpx;border:3rpx solid var(--clr-text);}
.css-ticket{width:24rpx;height:16rpx;border:3rpx solid var(--clr-text);border-radius:4rpx;border-left-style:dashed;border-right-style:dashed;}

.srp{background:#fcfdfa;}
.sln { flex: 1; font-size: 28rpx; color: var(--clr-text); font-weight:600;}
.sla { color: var(--clr-text-muted); font-size: 32rpx; }

.cban {
  margin: 40rpx 0; background: linear-gradient(135deg, #e8f5d8, #d4f299);
  border-radius: var(--radius-lg); padding: 40rpx; display: flex; align-items: center;
}
.ci { flex: 1; }
.cbt { font-size: 34rpx; font-weight: 900; color: var(--clr-primary); display: block; margin-bottom: 12rpx; }
.cbd { font-size: 24rpx; color: #4d7c0f; margin-bottom: 24rpx; display: block; line-height:1.5; font-weight:500;}
.cjbtn {
  background: var(--clr-primary); color: #fff; font-size: 24rpx; font-weight:800;
  padding: 16rpx 40rpx; border-radius: var(--radius-pill); display: inline-block; line-height: 1;margin:0;
}
.cq {
  width: 130rpx; height: 130rpx; background: #fff; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  margin-left: 24rpx; box-shadow: 0 4rpx 16rpx rgba(58,107,0,0.15);
}
.css-qr{width:60rpx;height:60rpx;border:4rpx dashed var(--clr-primary);position:relative;}
.css-qr::after{content:'';position:absolute;inset:10rpx;background:var(--clr-primary-light);}