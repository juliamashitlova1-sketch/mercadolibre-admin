<scroll-view scroll-y class="opage" enhanced show-scrollbar="{{false}}">
  <view class="card addr-card anim-fade-in" bindtap="pickAddr">
    <block wx:if="{{addr}}">
      <view class="ah">
        <text class="an">{{addr.userName}}</text>
        <text class="ap">{{addr.telNumber}}</text>
        <view class="at" wx:if="{{addr.isDefault}}">默认</view>
      </view>
      <text class="ad">{{addr.provinceName}}{{addr.cityName}}{{addr.countyName}}{{addr.detailInfo}}</text>
      <view class="css-arrow-right"></view>
    </block>
    <view wx:else class="addr-empty">
      <view class="css-pin-dark"></view>
      <text class="aet">请选择收货地址</text>
      <text class="aa">›</text>
    </view>
  </view>

  <view class="card anim-fade-in" style="animation-delay:0.1s">
    <view class="cl-top">
      <text class="cl">商品清单</text>
    </view>
    <block wx:for="{{items}}" wx:key="id">
      <view class="gi">
        <image class="gimg" src="{{item.image}}" mode="aspectFill" lazy-load></image>
        <view class="gn">
          <text class="gnname">{{item.name}}</text>
          <text class="gns">{{item.skuLabel || item.spec || '标准装'}}</text>
          <view class="gb">
            <text class="gpr">{{item.priceText}}</text>
            <text class="gqty">{{item.qtyText}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="card anim-fade-in" style="animation-delay:0.15s">
    <text class="cl">配送与支付</text>
    <view class="opt active border-btm">
      <view class="css-truck-opt"></view>
      <view class="oot">
        <text class="ootitle">极速送达</text>
        <text class="oodesc">预计明日准时送达</text>
      </view>
      <text class="ock">✓</text>
    </view>
    <view class="opt active">
      <view class="css-wechat"></view>
      <view class="oot">
        <text class="ootitle">微信支付</text>
      </view>
      <text class="ock">✓</text>
    </view>
  </view>

  <view class="card remark-card anim-fade-in" style="animation-delay:0.2s">
    <input class="ri" placeholder="订单备注（选填）" placeholder-style="color:var(--clr-text-muted)" value="{{remark}}" bindinput="onRm"></input>
  </view>

  <view class="card price-card anim-fade-in" style="animation-delay:0.25s">
    <view class="pr">
      <text class="pl">商品总金额</text>
      <text class="pv">{{gtText}}</text>
    </view>
    <view class="pr">
      <text class="pl">超轻物流费</text>
      <text class="pv free">免运费</text>
    </view>
    <view class="pr">
      <text class="pl">会员专享折扣</text>
      <text class="pv disc">{{dcText}}</text>
    </view>
    <view class="divider"></view>
    <view class="pr total">
      <text class="plt">合计</text>
      <text class="pvt">{{ftText}}</text>
    </view>
  </view>
  <view style="height:180rpx"></view>
</scroll-view>

<view class="submit-bar safe-area-bottom">
  <view class="si">
    <text class="sl">实付：</text>
    <text class="st">{{ftText}}</text>
  </view>
  <button class="sb" bindtap="submit" hover-class="sb-press">确认支付</button>
</view>