page { background: var(--clr-bg); }

/* 导航 */
.nav-bar{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;justify-content:center;align-items:center;
  padding:24rpx 36rpx;padding-top:calc(20rpx + env(safe-area-inset-top));
  background:rgba(253, 253, 248, 0.95);
  backdrop-filter:blur(20rpx);
  border-bottom:1rpx solid var(--clr-border);
}
.app-title{font-size:34rpx;font-weight:900;color:var(--clr-text);letter-spacing:2rpx;}

/* 内容区 */
.main.has-checkout{
  margin-top:calc(100rpx + env(safe-area-inset-top));
  padding:0 28rpx;
}
.safe-pad { height: 260rpx; } /* 防止被底栏遮挡 */

/* 选择器行 */
.sel-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:24rpx 8rpx;margin-bottom:12rpx;
}
.cbx{display:flex;align-items:center;gap:16rpx;}
.chk{
  width:38rpx;height:38rpx;border:3rpx solid #c2c7b8;border-radius:50%;
  position:relative;transition:all 0.2s;
}
.chk.on{background:var(--clr-primary);border-color:var(--clr-primary);}
.slt{font-size:26rpx;color:var(--clr-text-secondary);font-weight:600;}

/* CSS Check icon */
.css-check{
  position:absolute;top:10rpx;left:10rpx;width:16rpx;height:8rpx;
  border-left:4rpx solid #fff;border-bottom:4rpx solid #fff;
  transform:rotate(-45deg);
}

.del-btn{
  display:flex;align-items:center;gap:8rpx;
  font-size:24rpx;color:var(--clr-danger);font-weight:600;
  padding:8rpx 16rpx;border-radius:8rpx;
}
.del-press{background:rgba(211,47,47,0.08);}
.css-trash-small{
  width:20rpx;height:24rpx;border:3rpx solid var(--clr-danger);
  border-top:none;border-radius:0 0 4rpx 4rpx;position:relative;
}
.css-trash-small::before{
  content:'';position:absolute;top:-6rpx;left:-4rpx;right:-4rpx;
  height:3rpx;background:var(--clr-danger);
}

/* 列表 */
.clist{display:flex;flex-direction:column;gap:24rpx;}
.citem{
  display:flex;align-items:center;gap:20rpx;
  background:var(--clr-card);padding:24rpx;border-radius:24rpx;
  box-shadow:var(--shadow-sm);
}
.cimg-wrap{
  width:170rpx;height:170rpx;border-radius:16rpx;
  overflow:hidden;flex-shrink:0;background:#efefe8;position:relative;
}
.cimg{width:100%;height:100%;}
.cimg-fb{
  position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;background:linear-gradient(135deg,var(--clr-primary-light),#7dd327);
  font-size:56rpx;font-weight:900;color:white;
}

.cinfo{flex:1;display:flex;flex-direction:column;gap:10rpx;}
.cname{font-size:28rpx;font-weight:800;color:var(--clr-text);}
.cmid{display:flex;align-items:center;gap:12rpx;}
.spec-label{
  background:#f5f6f2;color:var(--clr-text-secondary);font-size:22rpx;
  padding:4rpx 12rpx;border-radius:8rpx;font-weight:600;
}
.ctag{
  font-size:18rpx;font-weight:800;padding:2rpx 10rpx;
  border-radius:6rpx;
}
.tp{color:var(--clr-primary);border:2rpx solid var(--clr-primary);}
.ts{color:#c62828;background:#ffcdd2;}

.cbtm{display:flex;justify-content:space-between;align-items:flex-end;margin-top:auto;}
.cpr{font-size:36rpx;font-weight:900;color:var(--clr-text);}

/* 步进器 */
.qty{
  display:flex;align-items:center;background:#f5f6f2;
  border-radius:12rpx;padding:4rpx;
}
.qbtn{
  width:48rpx;height:48rpx;border-radius:8rpx;
  position:relative;background:#fff;box-shadow:0 2rpx 6rpx rgba(0,0,0,0.04);
}
.qsub::before{
  content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:20rpx;height:4rpx;background:var(--clr-text);border-radius:2rpx;
}
.qadd::before, .qadd::after{
  content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  background:var(--clr-text);border-radius:2rpx;
}
.qadd::before{width:20rpx;height:4rpx;}
.qadd::after{height:20rpx;width:4rpx;}
.qnum{min-width:56rpx;text-align:center;font-size:28rpx;font-weight:800;color:var(--clr-text);}
.qpress{background:#e8ebdf;transform:scale(0.95);}

/* 结算悬浮 */
.checkout{
  position:fixed;bottom:140rpx;left:28rpx;right:28rpx;z-index:400; /* 放高一点避开tabBar */
  background:var(--clr-card);border-radius:32rpx;padding:24rpx 32rpx;
  display:flex;justify-content:space-between;align-items:center;
  box-shadow:0 12rpx 40rpx rgba(47,52,41,0.12);
}
.cl{display:flex;align-items:center;gap:32rpx;}
.slt-sm{font-size:26rpx;color:var(--clr-text-secondary);font-weight:600;}
.c-total-wrap{display:flex;align-items:baseline;}
.clbl{font-size:24rpx;font-weight:600;color:var(--clr-text);}
.ctotal{font-size:42rpx;font-weight:900;color:var(--clr-danger);}

.cobtn{
  padding:22rpx 56rpx;border-radius:var(--radius-pill);font-size:28rpx;
  font-weight:900;border:none;margin:0;line-height:1;transition:all 0.3s;
}
.cobtn.off{background:#eaece1;color:#b8bead;}
.cobtn.on{background:var(--clr-primary);color:var(--clr-card);box-shadow:0 8rpx 20rpx rgba(58,107,0,0.25);}
.btn-press{transform:scale(0.96);}

/* 空状态 */
.empty-page{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:120rpx 40rpx;margin-top:calc(100rpx + env(safe-area-inset-top));position:relative;
}
.eglow{
  position:absolute;width:400rpx;height:400rpx;
  background:rgba(161,250,73,0.15);border-radius:50%;filter:blur(80rpx);
}
.css-cart-large{
  width:120rpx;height:90rpx;border:8rpx solid var(--clr-border);
  border-top:none;border-radius:0 0 24rpx 24rpx;position:relative;margin-bottom:60rpx;
}
.css-cart-large::before{
  content:'';position:absolute;top:-20rpx;left:50%;transform:translateX(-50%);
  width:60rpx;height:24rpx;border:8rpx solid var(--clr-border);
  border-bottom:none;border-radius:40rpx 40rpx 0 0;
}
.etitle{font-size:40rpx;font-weight:900;color:var(--clr-text);z-index:2;position:relative;margin-bottom:16rpx;display:block;}
.edesc{font-size:26rpx;color:var(--clr-text-secondary);max-width:500rpx;line-height:1.6;z-index:2;position:relative;margin-bottom:48rpx;display:block;text-align:center;}
.ebtn{
  border:4rpx solid var(--clr-primary);color:var(--clr-primary);background:transparent;
  padding:24rpx 64rpx;border-radius:var(--radius-pill);font-size:28rpx;font-weight:900;
  letter-spacing:2rpx;margin-bottom:56rpx;z-index:2;position:relative;
}