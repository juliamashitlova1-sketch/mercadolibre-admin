page { background: var(--clr-bg); }

/* 导航栏 - 玻璃拟物 */
.nav-bar {
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;justify-content:space-between;align-items:center;
  padding:24rpx 28rpx;padding-top:calc(20rpx + env(safe-area-inset-top));
  background:rgba(253, 253, 248, 0.85);
  backdrop-filter:blur(24rpx); -webkit-backdrop-filter:blur(24rpx);
}
.nav-left{display:flex;align-items:center;gap:12rpx;}
.css-leaf{
  width:32rpx;height:32rpx;background:var(--clr-primary);
  border-radius:16rpx 0 16rpx 0; transform:rotate(-15deg);
}
.app-title{font-size:36rpx;font-weight:900;color:var(--clr-primary);letter-spacing:1rpx;}
.nav-right{display:flex;align-items:center;gap:16rpx;}

/* 地址组件 */
.location-badge{
  display:flex;align-items:center;gap:8rpx;
  background:var(--clr-primary-bg);padding:10rpx 20rpx;border-radius:var(--radius-pill);
}
.css-pin{
  width:16rpx;height:16rpx;border:3rpx solid var(--clr-primary);
  border-radius:50% 50% 50% 0;transform:rotate(-45deg);
}
.loc-text{font-size:23rpx;color:var(--clr-primary);font-weight:600;}

/* 头像 */
.avatar{
  width:68rpx;height:68rpx;border-radius:50%;
  border:4rpx solid #fff;box-shadow:var(--shadow-sm);background:#ecece5;
}

/* 主内容 */
.main-content{margin-top:calc(100rpx + env(safe-area-inset-top));padding:0 28rpx;}

/* 搜索栏 */
.search-bar{
  background:var(--clr-card);border-radius:var(--radius-pill);
  display:flex;align-items:center;height:90rpx;padding:0 32rpx;
  box-shadow:0 4rpx 16rpx rgba(47,52,41,0.03);margin:16rpx 0 36rpx;
}
.css-search{
  width:24rpx;height:24rpx;border:3rpx solid #afb4a5;border-radius:50%;
  position:relative;margin-right:20rpx;
}
.css-search::after{
  content:'';position:absolute;bottom:-6rpx;right:-8rpx;
  width:10rpx;height:3rpx;background:#afb4a5;transform:rotate(45deg);
}
.sp{font-size:28rpx;color:#afb4a5;font-weight:500;}

/* 横幅 */
.banner{
  height:260rpx;border-radius:var(--radius-lg);margin-bottom:40rpx;
  background:linear-gradient(135deg,#3a6b00,#244300);
  padding:40rpx;position:relative;overflow:hidden;
  box-shadow:0 12rpx 32rpx rgba(58,107,0,0.25);
}
.b-inner{display:flex;flex-direction:column;height:100%;justify-content:space-between;z-index:2;position:relative;}
.bt{font-size:46rpx;font-weight:900;color:var(--clr-primary-bg);line-height:1.2;letter-spacing:2rpx;}
.bs{font-size:24rpx;color:rgba(232,245,216,0.85);margin-top:8rpx;font-weight:500;}
.b-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:16rpx;}
.bb{
  align-self:flex-start;background:var(--clr-primary-light);color:#1c3300;
  padding:14rpx 44rpx;border-radius:var(--radius-pill);font-size:26rpx;font-weight:800;
  line-height:1;margin:0; box-shadow:0 4rpx 12rpx rgba(161,250,73,0.3);
}
.vip-badge{
  width:64rpx;height:64rpx;border-radius:50%;
  background:rgba(255,255,255,0.15);backdrop-filter:blur(8rpx);
  -webkit-backdrop-filter:blur(8rpx);
  display:flex;align-items:center;justify-content:center;
  color:white;font-size:20rpx;font-weight:900;
  border:2rpx solid rgba(255,255,255,0.2);
}
.bdec{
  position:absolute;right:-40rpx;top:-40rpx;
  width:200rpx;height:200rpx;border-radius:50%;
  background:radial-gradient(circle, rgba(161,250,73,0.15) 0%, transparent 70%);
}
.bdec2{
  position:absolute;right:30rpx;bottom:-30rpx;
  width:140rpx;height:140rpx;border-radius:50%;
  background:radial-gradient(circle, rgba(161,250,73,0.2) 0%, transparent 60%);
}

/* 分类 */
.sec{margin-bottom:44rpx;}
.shdr{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:28rpx;}
.stitle{font-size:36rpx;font-weight:900;color:var(--clr-text);}
.smore{font-size:26rpx;color:var(--clr-text-muted);font-weight:600;}
.cat-row{display:flex;justify-content:space-around;padding:0 10rpx;}
.cat-item{display:flex;flex-direction:column;align-items:center;gap:14rpx;transition:transform 0.1s;}
.cat-press{transform:scale(0.92);}
.cicon{
  width:104rpx;height:104rpx;border-radius:40rpx;
  display:flex;align-items:center;justify-content:center;
  box-shadow:var(--shadow-sm);
}
.cicon-txt{font-size:44rpx;font-weight:900;}
.cname{font-size:24rpx;font-weight:700;color:var(--clr-text-secondary);}

/* 物流 */
.drow{display:flex;gap:24rpx;margin-bottom:48rpx;}
.dcard{
  flex:1;border-radius:24rpx;padding:32rpx;min-height:200rpx;
  position:relative;overflow:hidden;display:flex;flex-direction:column;
  justify-content:space-between;
}
.dw{background:var(--clr-card);box-shadow:var(--shadow-md);}
.dgry{background:linear-gradient(135deg, #f5f6f0, #eaece1);}
.dcard-main{z-index:2;}
.dt{font-size:32rpx;font-weight:900;color:var(--clr-text);display:block;}
.dd{font-size:23rpx;color:var(--clr-text-secondary);margin-top:8rpx;display:block;}
.dcard-bottom{display:flex;justify-content:space-between;align-items:flex-end;z-index:2;}
.dib{
  width:64rpx;height:64rpx;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:28rpx;font-weight:bold;
}
.dg{background:var(--clr-primary-light);color:var(--clr-primary);}
.dw2{background:var(--clr-card);color:var(--clr-text);font-size:24rpx;}
.css-truck-wrap, .css-store-wrap {
  position:absolute;right:0rpx;bottom:-10rpx;
  width:120rpx;height:120rpx;background:radial-gradient(circle, rgba(0,0,0,0.03) 0%, transparent 60%);
}

/* 商品卡片 */
.plist{display:flex;flex-direction:column;gap:28rpx;}
.p-skeleton .skeleton{height:220rpx;}
.pcard{
  display:flex;align-items:stretch;gap:24rpx;
  background:var(--clr-card);padding:24rpx;border-radius:24rpx;
  box-shadow:var(--shadow-sm);
}
.pcard-press{background:#fcfdfa;transform:scale(0.99);}
.pimg-wrap{
  width:200rpx;height:200rpx;border-radius:18rpx;
  overflow:hidden;flex-shrink:0;position:relative;background:#efefe8;
}
.pimg{width:100%;height:100%;transition:opacity 0.3s;}
.pimg-fallback{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--clr-primary-light),#7dd327);
  transition:opacity 0.3s;
}
.pimg-fallback.hidden{opacity:0;pointer-events:none;}
.pf-text{font-size:64rpx;font-weight:900;color:white;opacity:0.9;}
.pinfo{flex:1;display:flex;flex-direction:column;min-width:0;justify-content:space-between;padding:4rpx 0;}
.ptag-row{display:flex;margin-bottom:8rpx;}
.ptag{
  font-size:18rpx;font-weight:800;padding:4rpx 14rpx;
  border-radius:9999rpx;display:inline-block;letter-spacing:1rpx;
}
.tp{color:var(--clr-primary);border:2rpx solid var(--clr-primary);background:transparent;}
.ts{color:#c62828;background:#ffcdd2;border:none;}
.tt{color:#f57f17;background:#fff9c4;border:none;}
.pname{font-size:30rpx;font-weight:900;color:var(--clr-text);line-height:1.4;}
.pdesc{font-size:24rpx;color:var(--clr-text-secondary);margin-top:6rpx;}
.pprice-wrap{display:flex;justify-content:space-between;align-items:flex-end;margin-top:12rpx;}
.pprice-box{display:flex;align-items:baseline;gap:8rpx;}
.pprice{font-size:38rpx;font-weight:900;color:var(--clr-text);}
.pop{font-size:24rpx;color:var(--clr-text-muted);text-decoration:line-through;}
.add-circle{
  width:64rpx;height:64rpx;border-radius:50%;background:var(--clr-primary-light);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.css-plus{
  width:24rpx;height:24rpx;position:relative;
}
.css-plus::before, .css-plus::after{
  content:'';position:absolute;background:#1a3a00;border-radius:2rpx;
}
.css-plus::before{top:10rpx;left:0;right:0;height:4rpx;}
.css-plus::after{bottom:0;top:0;left:10rpx;width:4rpx;}