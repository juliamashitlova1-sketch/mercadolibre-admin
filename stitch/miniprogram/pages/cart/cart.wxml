<view class="page">
  <view class="nav-bar">
    <text class="app-title">购物车</text>
  </view>

  <block wx:if="{{!empty}}">
    <view class="main has-checkout anim-fade-in">
      <view class="sel-row">
        <view class="cbx" bindtap="toggleAll">
          <view class="chk {{allSel?'on':''}}">
            <view wx:if="{{allSel}}" class="css-check"></view>
          </view>
          <text class="slt">全选所有商品</text>
        </view>
        <view class="del-btn" bindtap="delSel" hover-class="del-press">
          <view class="css-trash-small"></view>
          <text>移除选中项</text>
        </view>
      </view>

      <view class="clist">
        <block wx:for="{{items}}" wx:key="cartKey">
          <view class="citem">
            <view class="cbx" bindtap="toggleOne" data-i="{{index}}">
              <view class="chk {{item.sel?'on':''}}">
                <view wx:if="{{item.sel}}" class="css-check"></view>
              </view>
            </view>
            <view class="cimg-wrap">
              <image class="cimg" src="{{item.image}}" mode="aspectFill" lazy-load></image>
              <view class="cimg-fb" wx:if="{{!item.image}}">{{item.name[0]}}</view>
            </view>
            <view class="cinfo">
              <view class="ctop">
                <text class="cname text-line2">{{item.name}}</text>
              </view>
              
              <view class="cmid">
                <text class="spec-label">{{item.skuLabel || item.spec || '标准装'}}</text>
                <text class="ctag {{item.tagColor==='secondary'?'ts':'tp'}}">{{item.tag}}</text>
              </view>

              <view class="cbtm">
                <text class="cpr">{{item.priceText}}</text>
                <view class="qty">
                  <view class="qbtn qsub" bindtap="dec" data-i="{{index}}" hover-class="qpress" hover-stay-time="50"></view>
                  <text class="qnum">{{item.qty}}</text>
                  <view class="qbtn qadd" bindtap="inc" data-i="{{index}}" hover-class="qpress" hover-stay-time="50"></view>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
      <view class="safe-pad"></view>
    </view>

    <!-- 底部结算悬浮栏 -->
    <view class="checkout safe-area-bottom">
      <view class="cl">
        <view class="cbx" bindtap="toggleAll">
           <view class="chk {{allSel?'on':''}}"><view wx:if="{{allSel}}" class="css-check"></view></view>
           <text class="slt-sm">全选</text>
        </view>
        <view class="c-total-wrap">
          <text class="clbl">合计：</text>
          <text class="ctotal">{{totalText}}</text>
        </view>
      </view>
      <button class="cobtn {{scnt>0?'on':'off'}}" disabled="{{scnt===0}}" bindtap="checkout" hover-class="{{scnt>0?'btn-press':''}}">
        去结算({{scnt}})
      </button>
    </view>
  </block>

  <view wx:else class="empty-page anim-fade-in">
    <view class="eglow"></view>
    <view class="css-cart-large"></view>
    <text class="etitle">您的购物车空空如也~</text>
    <text class="edesc">暂未添加任何精选的有机美食。新鲜好物正在等您挑选。</text>
    <button class="ebtn" bindtap="goShop" hover-class="btn-press">去挑选商品</button>
  </view>
</view>