<view class="page">
  <view class="hdr">
    <view class="htop">
      <text class="htitle">我的馆长</text>
      <view class="hicons">
        <view class="icon-btn" bindtap="navTo" data-act="settings"><view class="css-settings"></view></view>
        <view class="icon-btn" bindtap="navTo" data-act="notifications"><view class="css-bell"></view></view>
      </view>
    </view>
    
    <view class="ucard anim-fade-in">
      <block wx:if="{{loggedIn && userInfo}}">
        <button class="uav-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="uav" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        </button>
      </block>
      <block wx:else>
        <button class="uav-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <view class="css-user-large"></view>
        </button>
      </block>
      
      <view class="uinfo">
        <text class="uw" wx:if="{{loggedIn}}">{{nickName}}</text>
        <text class="uw" wx:else>欢迎来到 Fresh Curator</text>
        <view class="ua-wrap">
          <text class="ua">{{loggedIn ? '超级会员' : '注册或绑定账号享受特权'}}</text>
        </view>
        <input wx:if="{{!loggedIn}}" class="nick-input" placeholder="输入您的专属昵称" placeholder-style="color:#b8bead;" bindconfirm="onNicknameInput"></input>
      </view>

      <button wx:if="{{!loggedIn}}" class="lbtn anim-scale-in" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">快速登录</button>
      <button wx:else class="lbtn lout anim-scale-in" bindtap="onLogout">退出状态</button>
    </view>
  </view>

  <scroll-view scroll-y class="main" enhanced show-scrollbar="{{false}}">
    <!-- 订单区 -->
    <view class="sec osec anim-fade-in" style="animation-delay: 0.1s">
      <view class="shdr">
        <text class="st">我的订单</text>
        <text class="sm" bindtap="navTo" data-act="orders">查看全部 ›</text>
      </view>
      <view class="ogrid">
        <view class="oitem" hover-class="oipress" data-act="orders-pending" bindtap="navTo">
          <view class="css-wallet"></view>
          <text class="ol">待付款</text>
        </view>
        <view class="oitem" hover-class="oipress" data-act="orders-shipping" bindtap="navTo">
          <view class="css-truck-line"></view>
          <text class="ol">待收货</text>
        </view>
        <view class="oitem" hover-class="oipress" data-act="orders-completed" bindtap="navTo">
          <view class="css-check-circle"></view>
          <text class="ol">已完成</text>
        </view>
        <view class="oitem" hover-class="oipress" data-act="orders-refund" bindtap="navTo">
          <view class="css-shield"></view>
          <text class="ol">售后/退款</text>
        </view>
      </view>
    </view>

    <!-- 服务区 -->
    <view class="sec anim-fade-in" style="animation-delay: 0.15s">
      <text class="st blk">精选服务</text>
      <view class="bento">
        <view class="bcard card-addr" hover-class="bc-press" bindtap="navTo" data-act="address">
          <view class="bi bg-pink"><view class="css-pin-w"></view></view>
          <text class="bn">地址管理</text>
        </view>
        <view class="bcard card-pts" hover-class="bc-press" bindtap="navTo" data-act="points">
          <view class="bi bg-yellow"><view class="css-star-w"></view></view>
          <text class="bn">我的积分</text>
          <text class="bp">1,240 <text class="bp-sm">Pts</text></text>
        </view>
      </view>

      <view class="slist">
        <view class="slrow" hover-class="srp" bindtap="navTo" data-act="receipt">
          <view class="sli-css"><view class="css-paper"></view></view>
          <text class="sln">电子凭证</text><text class="sla">›</text>
        </view>
        <view class="slrow" hover-class="srp" bindtap="navTo" data-act="contact">
          <view class="sli-css"><view class="css-headset"></view></view>
          <text class="sln">联系专属客服</text><text class="sla">›</text>
        </view>
        <view class="slrow" hover-class="srp" bindtap="shrRwd">
          <view class="sli-css"><view class="css-gift"></view></view>
          <text class="sln">邀请好友有礼</text><text class="sla">›</text>
        </view>
        <view class="slrow" hover-class="srp" bindtap="navTo" data-act="coupons">
          <view class="sli-css"><view class="css-ticket"></view></view>
          <text class="sln">我的优惠券</text><text class="sla">›</text>
        </view>
      </view>
    </view>

    <!-- 会员横幅 -->
    <view class="cban anim-fade-in" style="animation-delay: 0.2s">
      <view class="ci">
        <text class="cbt">加入馆长交流群</text>
        <text class="cbd">与其他生鲜美食家交流心得，获取每周专属群内隐藏优惠暗号。</text>
        <button class="cjbtn" bindtap="navTo" data-act="join_group">立即了解</button>
      </view>
      <view class="cq">
        <view class="css-qr"></view>
      </view>
    </view>
    <view style="height:200rpx"></view>
  </scroll-view>
</view>