<scroll-view scroll-y class="dpage" enhanced show-scrollbar="{{false}}">
  <swiper class="swp" indicator-dots indicator-color="rgba(175,180,165,0.3)" indicator-active-color="var(--clr-primary)">
    <swiper-item>
      <view class="swp-item" style="background:linear-gradient(135deg,var(--clr-primary-light),#7dd327)">
        <text class="swp-text">{{prod.name[0]||'鲜'}}</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="info anim-fade-in">
    <view class="itag {{prod.tagColor==='primary'?'itp':prod.tagColor==='secondary'?'its':'itt'}}">{{prod.tag}}</view>
    <text class="iname">{{prod.name}}</text>
    <text class="idesc">{{prod.description}}</text>
    
    <view class="iprow">
      <view class="price-ctn">
        <text class="icur">{{priceText}}</text>
        <text class="iold" wx:if="{{hasDiscount}}">{{originalPriceText}}</text>
      </view>
      <text class="idisc" wx:if="{{hasDiscount}}">{{discountText}}</text>
    </view>
  </view>

  <view class="sec anim-fade-in" style="animation-delay:0.1s">
    <text class="sl">规格选择</text>
    <view class="splist">
      <block wx:for="{{specs}}" wx:key="name">
        <view class="sp {{currentSpec===item.name?'sp-on':''}}" catchtap="selSpec" data-s="{{item.name}}">
          {{item.label}}
        </view>
      </block>
    </view>
  </view>

  <view class="sec dsec anim-fade-in" style="animation-delay:0.15s">
    <view class="dr">
      <view class="css-truck-small"></view>
      <view class="dinfo">
        <text class="dt">极速配送</text>
        <text class="dd">预计明日送达 · 享包邮特权</text>
      </view>
    </view>
    <view class="dr" bindtap="pickAddr">
      <view class="css-pin-small"></view>
      <view class="dinfo">
        <text class="dt">配送至</text>
        <text class="dd">{{addr||'请选择收货地址'}}</text>
      </view>
      <text class="ar">›</text>
    </view>
  </view>

  <view class="sec anim-fade-in" style="animation-delay:0.2s">
    <text class="sl">商品图文详情</text>
    <view class="desc">
      <text class="dp">{{prod.description}}</text>
      <text class="dp">所有商品均来自认证有机农场或全球优质直采，保证新鲜品质。我们采用全程冷链运输，锁住第一口鲜甜。</text>
      <text class="dp">如有任何质量或体验疑问，欢迎通过“我的”页面联系馆长客服团队。</text>
    </view>
  </view>
  <view style="height:180rpx"></view>
</scroll-view>

<view class="bot safe-area-bottom">
  <view class="bleft">
    <view class="baction" hover-class="bp" bindtap="goCart">
      <!-- CSS Cart Icon -->
      <view class="b-icon-wrap">
        <view class="css-cart-outline"></view>
        <view class="badg" wx:if="{{ccnt>0}}"><text class="badgetxt">{{ccnt}}</text></view>
      </view>
      <text class="bat">购物车</text>
    </view>
    <view class="baction" hover-class="bp" bindtap="onFav">
      <view class="b-icon-wrap">
        <view class="css-heart {{fav ? 'h-on' : ''}}"></view>
      </view>
      <text class="bat">{{fav?'已收藏':'收藏'}}</text>
    </view>
  </view>
  <view class="bright">
    <button class="btn-ac" catchtap="acart">加入购物车</button>
    <button class="btn-buy" catchtap="buy">立即购买</button>
  </view>
</view>