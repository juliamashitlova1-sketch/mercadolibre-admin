.tb{
  position:fixed;bottom:0;left:0;right:0;z-index:999;
  display:flex;justify-content:space-around;align-items:center;
  padding:16rpx 22rpx;
  padding-bottom:calc(24rpx + env(safe-area-inset-bottom));
  background:rgba(255,255,255,0.92);
  backdrop-filter:blur(20rpx);
  -webkit-backdrop-filter:blur(20rpx);
  border-radius:36rpx 36rpx 0 0;
  box-shadow:0 -6rpx 24rpx rgba(47,52,41,0.06);
}
.ti{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:10rpx 24rpx;position:relative;
  transition:all 0.2s ease;border-radius:var(--radius-pill,9999rpx);
}
.tipress{transform:scale(0.92);}
.ti.on{
  background:rgba(161,250,73,0.18);
}
.tt{
  font-size:20rpx;font-weight:500;color:#9ca394;
  letter-spacing:1rpx;display:block;margin-top:4rpx;
  transition:color 0.2s ease;
}
.ti.on .tt{color:#3a6b00;font-weight:700;}

/* ====== CSS Icons ====== */
.tab-icon{
  width:44rpx;height:44rpx;
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.css-icon{
  display:flex;align-items:center;justify-content:center;
  position:relative;
}

/* Home */
.css-home{width:28rpx;height:28rpx;position:relative;}
.h-body{
  width:20rpx;height:16rpx;
  border:3rpx solid #9ca394;border-top:none;border-radius:0 0 4rpx 4rpx;
  position:absolute;bottom:0;left:50%;transform:translateX(-50%);
}
.h-roof{
  width:0;height:0;
  border-left:14rpx solid transparent;
  border-right:14rpx solid transparent;
  border-bottom:12rpx solid #9ca394;
  position:absolute;top:0;left:50%;transform:translateX(-50%);
}
.ti.on .h-body{border-color:#3a6b00;}
.ti.on .h-roof{border-bottom-color:#3a6b00;}

/* Grid */
.css-grid{
  width:26rpx;height:26rpx;
  display:flex;flex-wrap:wrap;gap:4rpx;
  align-content:center;justify-content:center;
}
.g-dot{
  width:10rpx;height:10rpx;
  border-radius:3rpx;background:#9ca394;
  transition:background 0.2s ease;
}
.ti.on .g-dot{background:#3a6b00;}

/* Cart */
.css-cart{width:28rpx;height:28rpx;position:relative;}
.c-basket{
  width:22rpx;height:14rpx;
  border:3rpx solid #9ca394;border-top:none;
  border-radius:0 0 6rpx 6rpx;
  position:absolute;bottom:8rpx;left:50%;transform:translateX(-50%);
}
.c-basket::before{
  content:'';position:absolute;top:-10rpx;left:50%;
  transform:translateX(-50%);
  width:16rpx;height:8rpx;
  border:3rpx solid #9ca394;border-bottom:none;
  border-radius:8rpx 8rpx 0 0;
}
.c-wheels{
  display:flex;gap:10rpx;
  position:absolute;bottom:0;left:50%;transform:translateX(-50%);
}
.c-w{
  width:6rpx;height:6rpx;border-radius:50%;background:#9ca394;
  transition:background 0.2s ease;
}
.ti.on .c-basket{border-color:#3a6b00;}
.ti.on .c-basket::before{border-color:#3a6b00;}
.ti.on .c-w{background:#3a6b00;}

/* User */
.css-user{width:26rpx;height:28rpx;position:relative;}
.u-head{
  width:12rpx;height:12rpx;border-radius:50%;
  border:3rpx solid #9ca394;
  position:absolute;top:0;left:50%;transform:translateX(-50%);
}
.u-body{
  width:22rpx;height:10rpx;
  border:3rpx solid #9ca394;border-bottom:none;
  border-radius:12rpx 12rpx 0 0;
  position:absolute;bottom:0;left:50%;transform:translateX(-50%);
}
.ti.on .u-head{border-color:#3a6b00;}
.ti.on .u-body{border-color:#3a6b00;}

/* Badge */
.badge{
  position:absolute;top:-2rpx;right:4rpx;min-width:32rpx;height:32rpx;
  background:linear-gradient(135deg,#ef4444,#dc2626);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  padding:0 6rpx;box-shadow:0 2rpx 8rpx rgba(239,68,68,0.4);
}
.badgetxt{font-size:18rpx;font-weight:bold;color:white;display:block;}