<view class="tb">
  <block wx:for="{{list}}" wx:key="path">
    <view
      class="ti {{selected===index?'on':''}}"
      data-index="{{index}}"
      bindtap="switchTab"
      hover-class="tipress"
    >
      <!-- CSS-based icons -->
      <view class="tab-icon">
        <view wx:if="{{item.iconType==='home'}}" class="css-icon css-home">
          <view class="h-body"></view><view class="h-roof"></view>
        </view>
        <view wx:elif="{{item.iconType==='grid'}}" class="css-icon css-grid">
          <view class="g-dot"></view><view class="g-dot"></view>
          <view class="g-dot"></view><view class="g-dot"></view>
        </view>
        <view wx:elif="{{item.iconType==='cart'}}" class="css-icon css-cart">
          <view class="c-basket"></view><view class="c-wheels"><view class="c-w"></view><view class="c-w"></view></view>
        </view>
        <view wx:elif="{{item.iconType==='user'}}" class="css-icon css-user">
          <view class="u-head"></view><view class="u-body"></view>
        </view>
      </view>
      <text class="tt">{{item.text}}</text>
      <view class="badge" wx:if="{{index===2 && cartCount>0}}">
        <text class="badgetxt">{{cartCount}}</text>
      </view>
    </view>
  </block>
</view>