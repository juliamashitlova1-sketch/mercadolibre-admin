rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: dailyStats
    // Document ID: {date} (YYYY-MM-DD)
    // Fields:
    //   - date: string (required)
    //   - totalSales: number (required)
    //   - totalOrders: number (required)
    //   - adSpend: number
    //   - exchangeRate: number
    //   - questions: number
    //   - claims: number
    //   - reputation: string
    //
    // Collection: skuStats
    // Document ID: {skuDate} (SKU_YYYY-MM-DD)
    // Fields:
    //   - sku: string (required)
    //   - date: string (required)
    //   - sales: number (required)
    //   - orders: number (required)
    //   - adSpend: number
    //   - stock: number (required)
    //   - movingAvg7: number
    //   - movingAvg15: number
    //   - competitorPrice: number
    //   - rank: number
    //   - bid: number
    //   - slowStock: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "litacharriez@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidDailyStats(data) {
      return data.date is string &&
             data.totalSales is number &&
             data.totalOrders is number;
    }

    function isValidSKUStats(data) {
      return data.sku is string &&
             data.date is string &&
             data.sales is number &&
             data.orders is number &&
             data.stock is number;
    }

    match /dailyStats/{date} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidDailyStats(request.resource.data);
      allow delete: if isAdmin();
    }

    match /skuStats/{skuDate} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidSKUStats(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
